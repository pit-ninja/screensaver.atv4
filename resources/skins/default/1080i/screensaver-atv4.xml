<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<window type="window">
    <controls>
        <control type="image">
            <description>blackbackground</description>
            <posx>0</posx>
            <posy>0</posy>
            <colordiffuse>FF555555</colordiffuse>
            <aspectratio scalediffuse="false" align="center" aligny="center">scale</aspectratio>
            <width>1920</width>
            <height>1080</height>
            <texture>black.jpg</texture>
        </control>
        <control type="image" id="32500">
            <description>Background image</description>
            <posx>0</posx>
            <posy>0</posy>
            <colordiffuse>FF555555</colordiffuse>
            <aspectratio scalediffuse="false" align="center" aligny="center">scale</aspectratio>
            <width>1920</width>
            <height>1080</height>
            <texture>sanfrancisco.jpg</texture>
            <visible>!String.IsEqual(Window.Property(screensaver-atv4-loading),"false")</visible>
        </control>
        <control type="image" id="32501">
            <description>Busy animation</description>
            <posx>40</posx>
            <posy>1000</posy>
            <width>30</width>
            <height>30</height>
            <texture>busy.png</texture>
            <aspectratio>keep</aspectratio>
            <animation effect="rotate" start="0" end="360" center="55,1015" time="1200" loop="true" condition="true">conditional</animation>
            <visible>!String.IsEqual(Window.Property(screensaver-atv4-loading),"false")</visible>
        </control>
        <control type="label" id="32502">
            <top>975</top>
            <left>90</left>
            <width>600</width>
            <height>90</height>
            <font>font11</font>
            <textcolor>88FFFFFF</textcolor>
            <aligny>center</aligny>
            <align>left</align>
            <label/>
            <visible>!String.IsEqual(Window.Property(screensaver-atv4-loading),"false")</visible>
        </control>
        <control type="label" id="32503">
            <top>975</top>
            <left>40</left>
            <width>600</width>
            <height>90</height>
            <font>font11</font>
            <textcolor>88FFFFFF</textcolor>
            <aligny>center</aligny>
            <align>left</align>
            <label/>
        </control>
        <control type="videowindow">
            <description>VideoWindow</description>
            <posx>0</posx>
            <posy>0</posy>
            <width>1920</width>
            <height>1080</height>
            <visible>true</visible>
        </control>
        <!-- The Shutter Mask: Uses Explicit Visibility linking to guarantee perfectly synced fades -->
        <control type="image">
            <description>Transition Shutter</description>
            <posx>0</posx>
            <posy>0</posy>
            <width>1920</width>
            <height>1080</height>
            <texture>black.jpg</texture>
            <!-- Render solid black when fade-black is true -->
            <visible>String.IsEqual(Window.Property(fade-black),true)</visible>
            <!-- When True: Fade up to black -->
            <animation effect="fade" start="0" end="100" time="2000">Visible</animation>
            <!-- When False: Fade down to transparent -->
            <animation effect="fade" start="100" end="0" time="2000">Hidden</animation>
        </control>
        <control type="grouplist" id="32504">
            <bottom>55</bottom>
            <left>60</left>
            <width>1400</width>
            <height>180</height>
            <itemgap>0</itemgap>
            <align>bottom</align>
            <orientation>vertical</orientation>
            <visible>String.IsEqual(Window.Property(show-info),true) + String.IsEqual(Window.Property(fade-black),false) + String.IsEqual(Window.Property(poi-fade-out),false)</visible>
            <!-- When True: Fade in from transparent -->
            <animation effect="fade" start="0" end="100" time="2000">Visible</animation>
            <!-- When False: Fade out to transparent -->
            <animation effect="fade" start="100" end="0" time="2000">Hidden</animation>
            <control type="label" id="32502">
                <width>1400</width>
                <height>50</height>
                <font>font36_title</font>
                <textcolor>FFFFFFFF</textcolor>
                <shadowcolor>88000000</shadowcolor>
                <align>left</align>
                <aligny>bottom</aligny>
                <label>$INFO[Window.Property(AerialLocationLine1)]</label>
            </control>
            <control type="label" id="32503">
                <width>1400</width>
                <height>50</height>
                <font>font36_title</font>
                <textcolor>FFFFFFFF</textcolor>
                <shadowcolor>88000000</shadowcolor>
                <align>left</align>
                <aligny>bottom</aligny>
                <label>$INFO[Window.Property(AerialLocationLine2)]</label>
                <visible>!String.IsEmpty(Window.Property(AerialLocationLine2))</visible>
            </control>
        </control>
        <control type="grouplist" id="32505">
            <bottom>55</bottom>
            <right>60</right>
            <width>400</width>
            <height>180</height>
            <itemgap>0</itemgap>
            <align>bottom</align>
            <orientation>vertical</orientation>
            <visible>String.IsEqual(Window.Property(show-info),true) + String.IsEqual(Window.Property(fade-black),false)</visible>
            <!-- When True: Fade in from transparent -->
            <animation effect="fade" start="0" end="100" time="2000">Visible</animation>
            <!-- When False: Fade out to transparent -->
            <animation effect="fade" start="100" end="0" time="2000">Hidden</animation>
            <control type="label">
                <width>400</width>
                <height>50</height>
                <font>font36_title</font>
                <textcolor>FFFFFFFF</textcolor>
                <shadowcolor>88000000</shadowcolor>
                <align>right</align>
                <aligny>bottom</aligny>
                <label>$INFO[System.Time]</label>
            </control>
        </control>
    </controls>
</window>
